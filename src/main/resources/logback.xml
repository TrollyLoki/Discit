<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %boldCyan(%-34.-34thread) %red(%10.10mdc{jda.shard}) %boldGreen(%-20.-20logger{0})
                %highlight(%-6level) %boldMagenta(%-20.-20mdc{guild}) %magenta(%20.20mdc{user}) %msg%n
            </pattern>
        </encoder>
    </appender>

    <root level="info">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>